# DeepSeek API Key（用于智能对话，如需接入真实大模型，请填写后重新启动）
# 获取地址：https://platform.deepseek.com/
VITE_DEEPSEEK_API_KEY=

# DeepSeek API 地址
VITE_DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# 千问/Qwen-VL API Key（用于发票/图片 OCR 识别）
# 获取地址：https://dashscope.aliyun.com/
VITE_QIANWEN_API_KEY=

# 千问 API 地址（DashScope 兼容模式）
VITE_QIANWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# 千问多模态模型（图片识别）
VITE_QIANWEN_VL_MODEL=qwen-vl-plus

# 可选：Embedding API（如果你希望用 OpenAI/智谱等 Embedding 替代本地 TF-IDF）
# VITE_OPENAI_API_KEY=your_key
# VITE_OPENAI_API_URL=https://api.openai.com/v1/embeddings
# VITE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
